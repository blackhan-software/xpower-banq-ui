{
    "configurations": [
        {
            "console": "integratedTerminal",
            "name": "Dev [Main]",
            "request": "launch",
            "type": "node",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run-script",
                "dev@mainnet"
            ],
            "skipFiles": [
                "<node_internals>/**"
            ]
        },
        {
            "console": "integratedTerminal",
            "name": "Dev [Test]",
            "request": "launch",
            "type": "node",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run-script",
                "dev@testnet"
            ],
            "skipFiles": [
                "<node_internals>/**"
            ]
        },
        {
            "console": "integratedTerminal",
            "name": "Vitest Run",
            "request": "launch",
            "type": "node",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run-script",
                "test",
                "${file}"
            ],
            "skipFiles": [
                "<node_internals>/**"
            ]
        },
        {
            "name": "Attach",
            "port": 9222,
            "request": "attach",
            "type": "chrome",
            "webRoot": "${workspaceFolder}"
        }
    ]
}